# ============================================================
#  .env.example  —  Local AI Coding Agent — Environment Config
#  Copy this to .env and fill in your values.
#  On Replit: use the Secrets panel instead of this file.
# ============================================================

# ── OLLAMA ───────────────────────────────────────────────────
# URL of your Ollama instance
OLLAMA_URL=http://localhost:11434

# Default model (must be pulled in Ollama first)
# Pull with: ollama pull <model_name>
# Examples:  qwen2.5-coder:7b   llama3.2   codellama   mistral
AGENT_MODEL=qwen2.5-coder:7b

# ── SERVER ───────────────────────────────────────────────────
# Express backend port
PORT=3131

# ── TELEGRAM BOT (optional) ──────────────────────────────────
# Get a token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Who can use the bot — comma-separated IDs or @usernames.
# Leave empty to allow everyone (risky!).
# Example: ALLOWED_USERS=123456789,987654321,@myusername
ALLOWED_USERS=
